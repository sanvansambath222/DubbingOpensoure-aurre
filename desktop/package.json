{
  "name": "voxidub-desktop",
  "version": "1.0.0",
  "description": "VoxiDub.AI - AI Video Dubbing Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-react": "cd ../frontend && REACT_APP_BACKEND_URL=http://localhost:8001 yarn build && cp -r build ../desktop/build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist-win": "electron-builder --win"
  },
  "author": "VoxiDub.AI",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.voxidub.ai",
    "productName": "VoxiDub.AI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "license.js",
      "splash.html",
      "build/**/*",
      "backend/**/*",
      "!backend/venv/**",
      "!backend/__pycache__/**",
      "!backend/tests/**",
      "!backend/.env"
    ],
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg",
        "filter": ["**/*"]
      },
      {
        "from": "python/",
        "to": "python",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.png",
      "uninstallerIcon": "icon.png",
      "installerHeaderIcon": "icon.png"
    }
  }
}
